rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeamMember(teamId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/equipes/$(teamId)/membros/$(request.auth.uid));
    }

    function isTeamAdmin(teamId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/equipes/$(teamId)/membros/$(request.auth.uid)).data.role == "admin";
    }


    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /amizades/{amizadeId} {
      allow read: if isSignedIn() && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.userA == request.auth.uid
        && request.resource.data.userA != request.resource.data.userB
        && request.resource.data.status == "pendente";

      allow update: if isSignedIn()
        && resource.data.status == "pendente"
        && request.resource.data.status == "aceita"
        && request.resource.data.userA == resource.data.userA
        && request.resource.data.userB == resource.data.userB
        && request.auth.uid == resource.data.userB;

      allow delete: if false;
    }

    match /equipes/{equipeId} {
      allow create: if isSignedIn() && request.resource.data.criadorId == request.auth.uid;
      allow read: if isTeamMember(equipeId);
      allow update, delete: if isTeamAdmin(equipeId);

      match /membros/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isTeamMember(equipeId));

        allow create: if isTeamAdmin(equipeId)
          || (isSignedIn()
            && request.auth.uid == userId
            && get(/databases/$(database)/documents/equipes/$(equipeId)).data.criadorId == request.auth.uid
            && request.resource.data.role == "admin");

        allow update, delete: if isTeamAdmin(equipeId);
      }
    }

    match /convitesEquipe/{conviteId} {
      allow read: if isSignedIn() && resource.data.convidadoId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.convidadoPorId == request.auth.uid
        && request.resource.data.status == "pendente";

      allow update: if isSignedIn()
        && resource.data.convidadoId == request.auth.uid
        && resource.data.status == "pendente"
        && request.resource.data.convidadoId == resource.data.convidadoId
        && request.resource.data.convidadoPorId == resource.data.convidadoPorId
        && request.resource.data.equipeId == resource.data.equipeId
        && request.resource.data.status in ["aceito", "recusado"];

      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read, update: if isSignedIn()
        && (resource.data.empresaId == request.auth.uid || resource.data.freelancerId == request.auth.uid);

      allow create: if isSignedIn()
        && (request.resource.data.empresaId == request.auth.uid || request.resource.data.freelancerId == request.auth.uid);

      match /mensagens/{mensagemId} {
        allow read, create: if isSignedIn()
          && exists(/databases/$(database)/documents/chats/$(chatId))
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.empresaId == request.auth.uid
            || get(/databases/$(database)/documents/chats/$(chatId)).data.freelancerId == request.auth.uid);
      }
    }

    match /chatsAmizade/{chatId} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;

      match /mensagens/{mensagemId} {
        allow read, create: if isSignedIn()
          && exists(/databases/$(database)/documents/chatsAmizade/$(chatId))
          && request.auth.uid in get(/databases/$(database)/documents/chatsAmizade/$(chatId)).data.participants;
      }
    }

    match /chatsEquipe/{chatId} {
      allow read: if isSignedIn() && isTeamMember(chatId);

      allow create: if isSignedIn()
        && request.resource.data.equipeId == chatId
        && isTeamMember(chatId)
        && request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn()
        && isTeamMember(chatId)
        && request.resource.data.equipeId == resource.data.equipeId;

      match /mensagens/{mensagemId} {
        allow read, create: if isSignedIn()
          && exists(/databases/$(database)/documents/chatsEquipe/$(chatId))
          && isTeamMember(chatId);
      }
    }
  }
}
